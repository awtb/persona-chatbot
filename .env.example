# Minimal Docker-first configuration.
# DB, Redis, ports, worker concurrency, CORS, and logging already have Compose defaults.

TG_BOT_TOKEN=replace-me
TG_BOT_WEBHOOK_URL=https://example.com/webhook
TG_BOT_WEBHOOK_TOKEN=replace-me

# If the worker runs in Docker and Ollama runs on the host,
# `host.docker.internal` is the usual choice.
LLM_PROVIDER_API_KEY=ollama
LLM_PROVIDER_BASE_URL=http://host.docker.internal:11434/v1
LLM_MODEL=llama3.2

CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_CREDENTIALS=true
